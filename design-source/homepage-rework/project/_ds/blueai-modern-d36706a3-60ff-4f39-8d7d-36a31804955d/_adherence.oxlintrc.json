      "--bai-surface",
      "--bg-canvas",
      "--bg-surface",
      "--border-card",
      "--border-composer",
      "--border-divider",
      "--border-hairline",
      "--border-header",
      "--dur-base",
      "--dur-fast",
      "--dur-slow",
      "--ease-out",
      "--fg-1",
      "--fg-2",
      "--fg-3",
      "--fg-4",
      "--fg-disabled",
      "--font-brand",
